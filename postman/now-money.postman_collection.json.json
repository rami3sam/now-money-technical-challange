    {
      "name": "Provide Transaction Status(Webhook)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const secret = 'RAMI'; // Your shared secret key\r",
              "// Access the request body. Note: this might need adjustment depending on body type (raw, form-data, etc.)\r",
              "let payload = pm.request.body.raw; \r",
              "\r",
              "// If the body is empty, you might need special handling based on API spec.\r",
              "if (!payload) {\r",
              "    payload = \"\"; \r",
              "}\r",
              "\r",
              "// Calculate the HMAC SHA256 hash using the built-in CryptoJS library.\r",
              "const hmacHash = CryptoJS.HmacSHA256(payload, secret);\r",
              "\r",
              "// Encode the hash (Base64 is common, but check API requirements).\r",
              "const signature = CryptoJS.enc.Base64.stringify(hmacHash); \r",
              "\r",
              "// Add the signature to the request headers.\r",
              "pm.request.headers.add({\r",
              "    key: 'X-Signature',\r",
              "    value: signature\r",
              "});\r",
              "\r",
              "console.log(\"Signature :: \" + signature);\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
